      </span>
    </div>
    <ul
      class="flex items-center gap-2"
    >
      <li>
        <button
          aria-label="View official Amazon catalog image"
          aria-pressed="true"
          class="block h-14 w-14 overflow-hidden rounded-amazon border bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-amazonOrange border-amazonOrange ring-1 ring-amazonOrange"
          type="button"
        >
          <span
            class="block overflow-hidden rounded-amazon bg-white h-full w-full"
          >
            <img
              alt="Sony WH-CH520 Wireless Headphones — official Amazon catalog image"
              class="h-full w-full object-contain "
              data-placeholder="false"
              src="https://example.com/official-catalog.jpg"
            />
          </span>
        </button>
      </li>
      <li>
        <div
          class="relative"
        >
          <span
