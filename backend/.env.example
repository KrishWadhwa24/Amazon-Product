# Amazon Edge-Return backend environment configuration.
# Copy this file to `.env` and adjust values for your local setup.

# PostgreSQL connection (async, SQLAlchemy + asyncpg driver).
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/amazon_edge_return

# Redis connection used for the geospatial demand index.
REDIS_URL=redis://localhost:6381/0

# Secret used to sign HTTP-only session cookies. Use a long random value in production.
SESSION_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of allowed CORS origins (the Next.js dev client).
CORS_ORIGINS=http://localhost:3000

